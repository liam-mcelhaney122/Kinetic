# =============================================================================
# Kinetic — single source of truth for environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# In production, set all secrets via: fly secrets set KEY=value --app kinetic-api
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB (used by docker-compose for the dev mongo container AND by the API)
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=your_username_here
MONGO_INITDB_ROOT_PASSWORD=your_password_here
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=kinetic
MONGO_URI=mongodb://your_username_here:your_password_here@mongo:27017/kinetic?authSource=admin
# Production Atlas URI format:
# MONGO_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/kinetic?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Auth — Clerk
# -----------------------------------------------------------------------------
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=                     # JWT audience claim; leave empty if not configured
MCP_DEV_SECRET=localdevsecret       # dev-only auto-login; leave empty in production

# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: CORS_ORIGINS=https://kinetic-frontend.fly.dev

# -----------------------------------------------------------------------------
# OpenAI (used by /generate endpoint + MCP generate_workout tool)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Frontend (Vite) — variables prefixed VITE_ are bundled into the client
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# -----------------------------------------------------------------------------
# MCP server (only needed if running the MCP locally)
# -----------------------------------------------------------------------------
KINETIC_API_URL=http://localhost:8000
KINETIC_USER_ID=user_your_clerk_user_id_here
# KINETIC_API_KEY=kt_your_api_key_here   # optional manual key, overrides auto-login
